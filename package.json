{
  "name": "openapi-k6",
  "version": "0.1.1",
  "description": "OpenAPI-based scenario validation and k6 load test generator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aqwsde321/openapi-k6-runner.git"
  },
  "bugs": {
    "url": "https://github.com/aqwsde321/openapi-k6-runner/issues"
  },
  "homepage": "https://github.com/aqwsde321/openapi-k6-runner#readme",
  "type": "module",
  "bin": {
    "openapi-k6": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/03-maintainer-notes.md",
    ".env.example"
  ],
  "keywords": [
    "openapi",
    "k6",
    "load-test",
    "scenario",
    "api-testing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && pnpm run build:assets",
    "build:assets": "mkdir -p dist/scaffold/templates && cp src/scaffold/templates/load-tests.README.md dist/scaffold/templates/load-tests.README.md",
    "build:watch": "pnpm run build:assets && tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2"
}
